{
  "$schema": "OIO Apex brand tokens — extracted from oio-apex-brand-guide.html and HANDOFF.md. Single source of truth for all video components; nothing downstream should re-derive a brand value.",
  "color": {
    "base": {
      "black": "#000000",
      "surface": "#161412",
      "surface2": "#1e1b18",
      "white": "#ffffff",
      "line": "#3a342c",
      "muted": "#9a9083",
      "muted2": "#6b6355"
    },
    "core": {
      "spark": {
        "role": "payoff/victory — mood pick",
        "ramp": {
          "100": "#FDF3CC",
          "300": "#F9DA66",
          "500": "#F5C200",
          "700": "#9F7E00",
          "900": "#564400"
        }
      },
      "grit": {
        "role": "struggle/mechanical — mood pick",
        "ramp": {
          "100": "#F6D6D2",
          "300": "#E48378",
          "500": "#D2301E",
          "700": "#891F14",
          "900": "#4A110B"
        }
      }
    },
    "support": {
      "rust": {
        "role": "vintage/patina only — not a mood pick",
        "ramp": {
          "100": "#F9E2D2",
          "300": "#ECA979",
          "500": "#E07020",
          "700": "#924915",
          "900": "#4E270B"
        }
      },
      "flag": {
        "role": "confirmation/pricing signal only — not a mood pick",
        "ramp": {
          "100": "#DBECDA",
          "300": "#94C58F",
          "500": "#4C9F45",
          "700": "#31672D",
          "900": "#1B3818"
        }
      }
    },
    "neutral": {
      "black": "#000000",
      "white": "#FFFFFF",
      "gray900": "#1A1A1A",
      "gray100": "#E5E5E5",
      "muted": "#9A9083",
      "muted2": "#6B6355",
      "line": "#3A342C"
    }
  },
  "type": {
    "scale": {
      "caption": "0.75rem",
      "body": "1rem",
      "h6": "1.125rem",
      "h5": "1.375rem",
      "h4": "1.75rem",
      "h3": "2.25rem",
      "h2": "2.875rem",
      "h1": "3.625rem",
      "heroSm": "4.5rem",
      "heroMd": "5.75rem",
      "heroLg": "7.5rem",
      "heroXl": "10rem"
    },
    "fonts": {
      "helvetica": {
        "stack": ["Helvetica Neue", "Helvetica", "Arial", "sans-serif"],
        "role": "lead/body, full size range"
      },
      "condensedBlack": {
        "stack": ["Helvetica Neue Condensed Black", "Arial Narrow Bold", "Haettenschweiler", "sans-serif"],
        "role": "display/punch only, never below H2, no italic ever",
        "note": "Possibly orphaned per HANDOFF.md — hero punch moved to wide Helvetica Bold/Black. Still used for corner-label numerals/leaderboard digits per this project's design direction."
      },
      "signPainter": {
        "stack": ["SignPainter-HouseScript", "SignPainter", "Brush Script MT", "Apple Chancery", "cursive"],
        "role": "vintage script, hero sizes only (120-160px), flat color only — no gradient/outline/drop-shadow"
      },
      "mono": {
        "stack": ["SF Mono", "Menlo", "Consolas", "monospace"],
        "role": "tabular numerals, codes"
      }
    },
    "neverItalic": true
  },
  "cornerLabel": {
    "layout": "flexbox, two parts, no gap (flush)",
    "partPadding": "0.32em 0.55em",
    "partFontSize": "h5",
    "partFontWeight": 700,
    "rule": "left = fact (year/make/model or event category), right = name/sub-fact. Box always sits on the outer frame edge. Box always contrasts with its own background: white box on a dark shot, black box on a light shot. Unboxed side matches the frame color, not the box.",
    "onDark": { "boxBg": "white", "boxColor": "black", "plainColor": "white" },
    "onLight": { "boxBg": "black", "boxColor": "white", "plainColor": "black" }
  },
  "spacing": {
    "sheetMaxWidth": "920px",
    "sheetPadding": "0 2rem",
    "ruleMargin": "3.2rem 0"
  },
  "frame": {
    "video": { "width": 1920, "height": 1080, "aspectRatio": "16 / 9" }
  }
}
